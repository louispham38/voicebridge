{
  "manifest_version": 3,
  "name": "VoiceBridge – Real-time Voice Translator",
  "version": "2.0.0",
  "description": "Dịch real-time tiếng Anh → tiếng Việt bằng giọng nói. Hỗ trợ voice cloning, panel nổi, sửa dịch thông minh. Zoom, YouTube, Meet, Teams.",
  "permissions": [
    "tabCapture",
    "offscreen",
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "VoiceBridge",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
